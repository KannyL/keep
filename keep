import React, { useState, useEffect, useCallback, useRef } from 'react';
import { 
  Camera, 
  Image as ImageIcon, 
  Copy, 
  Download, 
  Maximize2, 
  Upload, 
  Loader2, 
  Zap, 
  CheckCircle2,
  AlertCircle
} from 'lucide-react';

const App = () => {
  const [activeTab, setActiveTab] = useState('deskripsi');
  const [image, setImage] = useState(null);
  const [imagePreview, setImagePreview] = useState(null);
  const [prompt, setPrompt] = useState('');
  const [loading, setLoading] = useState(false);
  const [output, setOutput] = useState(null);
  const [error, setError] = useState(null);
  const [copied, setCopied] = useState(false);

  const apiKey = ""; // Disetel otomatis oleh lingkungan

  // Handle Global Paste
  useEffect(() => {
    const handlePaste = (event) => {
      const items = event.clipboardData.items;
      for (let i = 0; i < items.length; i++) {
        if (items[i].type.indexOf("image") !== -1) {
          const blob = items[i].getAsFile();
          processFile(blob);
          break;
        }
      }
    };

    window.addEventListener('paste', handlePaste);
    return () => window.removeEventListener('paste', handlePaste);
  }, []);

  const processFile = (file) => {
    if (!file) return;
    const reader = new FileReader();
    reader.onloadend = () => {
      setImage(reader.result.split(',')[1]);
      setImagePreview(reader.result);
    };
    reader.readAsDataURL(file);
  };

  const handleFileUpload = (e) => {
    const file = e.target.files[0];
    processFile(file);
  };

  const handleDragOver = (e) => {
    e.preventDefault();
  };

  const handleDrop = (e) => {
    e.preventDefault();
    const file = e.dataTransfer.files[0];
    processFile(file);
  };

  const callGeminiVision = async (base64Data) => {
    setLoading(true);
    setError(null);
    setOutput(null);

    const systemPrompt = `Deskripsikan gambar ini dengan sangat detail dalam bahasa Indonesia. 
    ATURAN KETAT: 
    1. JANGAN menyebutkan atau mendeskripsikan: Etnis, Rambut, Gaya Rambut, warna Rambut, Kumis, Janggut, atau Jenggot. 
    2. JANGAN mendeskripsikan wajah hingga kepala sama sekali, KECUALI ekspresi wajah (seperti tersenyum, marah, sedih).
    3. Tambahkan kalimat "(gambar referensi)" segera setelah subjek utama disebutkan pertama kali.
    4. JANGAN menggunakan kata pembuka seperti "Gambar ini menunjukkan" atau "Dalam gambar ini". Langsung ke deskripsi.
    Contoh: "seorang wanita (gambar referensi) sedang berdiri dengan senyum gembira menggunakan baju hijau..."`;

    try {
      let response;
      let delay = 1000;
      for (let i = 0; i < 5; i++) {
        try {
          const res = await fetch(`https://generativelanguage.googleapis.com/v1beta/models/gemini-2.5-flash-preview-09-2025:generateContent?key=${apiKey}`, {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({
              contents: [{
                parts: [
                  { text: systemPrompt },
                  { inlineData: { mimeType: "image/png", data: base64Data } }
                ]
              }]
            })
          });
          if (res.ok) {
            response = await res.json();
            break;
          }
        } catch (e) {
          if (i === 4) throw e;
          await new Promise(r => setTimeout(r, delay));
          delay *= 2;
        }
      }

      const text = response.candidates?.[0]?.content?.parts?.[0]?.text;
      if (text) {
        setOutput(text.trim());
      } else {
        throw new Error("Gagal mendapatkan deskripsi.");
      }
    } catch (err) {
      setError("Terjadi kesalahan saat menghubungi AI. Silakan coba lagi.");
    } finally {
      setLoading(false);
    }
  };

  const callGeminiGenerate = async (base64Data, userPrompt) => {
    setLoading(true);
    setError(null);
    setOutput(null);

    try {
      let response;
      let delay = 1000;
      for (let i = 0; i < 5; i++) {
        try {
          const res = await fetch(`https://generativelanguage.googleapis.com/v1beta/models/gemini-2.5-flash-image-preview:generateContent?key=${apiKey}`, {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({
              contents: [{
                parts: [
                  { text: userPrompt },
                  { inlineData: { mimeType: "image/png", data: base64Data } }
                ]
              }],
              generationConfig: { responseModalities: ['TEXT', 'IMAGE'] }
            })
          });
          if (res.ok) {
            response = await res.json();
            break;
          }
        } catch (e) {
          if (i === 4) throw e;
          await new Promise(r => setTimeout(r, delay));
          delay *= 2;
        }
      }

      const base64Image = response.candidates?.[0]?.content?.parts?.find(p => p.inlineData)?.inlineData?.data;
      if (base64Image) {
        setOutput(`data:image/png;base64,${base64Image}`);
      } else {
        throw new Error("Gagal menghasilkan gambar.");
      }
    } catch (err) {
      setError("Terjadi kesalahan saat menghasilkan gambar.");
    } finally {
      setLoading(false);
    }
  };

  const copyToClipboard = () => {
    const el = document.createElement('textarea');
    el.value = output;
    document.body.appendChild(el);
    el.select();
    document.execCommand('copy');
    document.body.removeChild(el);
    setCopied(true);
    setTimeout(() => setCopied(false), 2000);
  };

  const downloadImage = () => {
    const link = document.createElement('a');
    link.href = output;
    link.download = `NYETAK_Generated_${Date.now()}.png`;
    link.click();
  };

  return (
    <div className="min-h-screen bg-zinc-950 text-zinc-100 font-sans selection:bg-emerald-500/30 selection:text-emerald-400">
      {/* Navigation */}
      <nav className="border-b border-zinc-800/50 backdrop-blur-md sticky top-0 z-50">
        <div className="max-w-5xl mx-auto px-6 h-16 flex items-center justify-between">
          <div className="flex items-center gap-2 group cursor-default">
            <div className="w-8 h-8 bg-emerald-500 rounded-lg flex items-center justify-center animate-pulse shadow-[0_0_15px_rgba(16,185,129,0.4)]">
              <Zap className="w-5 h-5 text-zinc-950 fill-current" />
            </div>
            <h1 className="text-2xl font-black tracking-tighter group-hover:text-emerald-400 transition-colors">
              NYETAK
            </h1>
          </div>
          
          <div className="flex bg-zinc-900/50 p-1 rounded-full border border-zinc-800">
            <button 
              onClick={() => { setActiveTab('deskripsi'); setOutput(null); setImagePreview(null); setImage(null); }}
              className={`px-6 py-1.5 rounded-full text-sm font-medium transition-all duration-300 ${activeTab === 'deskripsi' ? 'bg-emerald-600 text-white shadow-lg' : 'text-zinc-400 hover:text-zinc-200'}`}
            >
              Deskripsi
            </button>
            <button 
              onClick={() => { setActiveTab('generate'); setOutput(null); setImagePreview(null); setImage(null); }}
              className={`px-6 py-1.5 rounded-full text-sm font-medium transition-all duration-300 ${activeTab === 'generate' ? 'bg-emerald-600 text-white shadow-lg' : 'text-zinc-400 hover:text-zinc-200'}`}
            >
              Generate
            </button>
          </div>
        </div>
      </nav>

      <main className="max-w-4xl mx-auto px-6 py-12">
        <div className="grid grid-cols-1 md:grid-cols-2 gap-12 items-start">
          
          {/* Left Column: Input */}
          <section className="space-y-6 animate-in fade-in slide-in-from-left-4 duration-700">
            <div className="space-y-2">
              <h2 className="text-lg font-semibold flex items-center gap-2">
                {activeTab === 'deskripsi' ? <Camera className="w-5 h-5 text-emerald-500" /> : <ImageIcon className="w-5 h-5 text-emerald-500" />}
                {activeTab === 'deskripsi' ? 'Input Gambar' : 'Modifikasi Gambar'}
              </h2>
              <p className="text-sm text-zinc-500">
                Klik untuk unggah, seret file ke sini, atau langsung <span className="text-emerald-500 font-mono">CTRL+V</span>.
              </p>
            </div>

            <div 
              onDragOver={handleDragOver}
              onDrop={handleDrop}
              className={`relative aspect-square rounded-2xl border-2 border-dashed transition-all group overflow-hidden ${imagePreview ? 'border-emerald-500/50' : 'border-zinc-800 hover:border-emerald-500/40 bg-zinc-900/30'}`}
            >
              {imagePreview ? (
                <div className="relative w-full h-full">
                  <img src={imagePreview} alt="Preview" className="w-full h-full object-cover" />
                  <button 
                    onClick={() => {setImagePreview(null); setImage(null);}}
                    className="absolute top-4 right-4 p-2 bg-black/60 backdrop-blur-md rounded-full hover:bg-red-500 transition-colors"
                  >
                    <Maximize2 className="w-4 h-4 rotate-45" />
                  </button>
                </div>
              ) : (
                <label className="flex flex-col items-center justify-center w-full h-full cursor-pointer">
                  <div className="p-4 bg-zinc-900 rounded-2xl group-hover:scale-110 transition-transform duration-500 group-hover:shadow-[0_0_20px_rgba(16,185,129,0.1)]">
                    <Upload className="w-8 h-8 text-zinc-600 group-hover:text-emerald-500" />
                  </div>
                  <span className="mt-4 text-sm font-medium text-zinc-600 group-hover:text-zinc-400">Pilih Media</span>
                  <input type="file" className="hidden" accept="image/*" onChange={handleFileUpload} />
                </label>
              )}
            </div>

            {activeTab === 'generate' && (
              <div className="space-y-3">
                <label className="text-sm font-medium text-zinc-400">Modifikasi Prompt</label>
                <textarea 
                  value={prompt}
                  onChange={(e) => setPrompt(e.target.value)}
                  placeholder="Contoh: Ubah suasana menjadi malam hari dengan lampu neon..."
                  className="w-full h-24 bg-zinc-900/50 border border-zinc-800 rounded-xl p-4 text-sm focus:outline-none focus:ring-2 focus:ring-emerald-500/50 focus:border-emerald-500/50 transition-all resize-none"
                />
              </div>
            )}

            <button 
              disabled={loading || !image || (activeTab === 'generate' && !prompt)}
              onClick={() => activeTab === 'deskripsi' ? callGeminiVision(image) : callGeminiGenerate(image, prompt)}
              className="w-full bg-emerald-600 hover:bg-emerald-500 disabled:opacity-50 disabled:cursor-not-allowed text-white py-4 rounded-xl font-bold tracking-wide transition-all shadow-[0_4px_20px_rgba(16,185,129,0.2)] flex items-center justify-center gap-3 active:scale-[0.98]"
            >
              {loading ? <Loader2 className="w-5 h-5 animate-spin" /> : activeTab === 'deskripsi' ? 'EKSTRAK DESKRIPSI' : 'GENERATE GAMBAR'}
            </button>
          </section>

          {/* Right Column: Output */}
          <section className="space-y-6 animate-in fade-in slide-in-from-right-4 duration-700">
            <div className="space-y-2">
              <h2 className="text-lg font-semibold flex items-center gap-2">
                <CheckCircle2 className="w-5 h-5 text-emerald-500" />
                Hasil Proses
              </h2>
              <p className="text-sm text-zinc-500">Output akan muncul di bawah ini secara instan.</p>
            </div>

            <div className={`min-h-[300px] w-full rounded-2xl bg-zinc-900/50 border border-zinc-800 p-6 flex items-center justify-center relative overflow-hidden transition-all ${output ? 'border-emerald-500/20' : ''}`}>
              {!output && !loading && !error && (
                <div className="text-center space-y-2">
                  <div className="w-12 h-12 bg-zinc-800 rounded-full flex items-center justify-center mx-auto opacity-20">
                    <Zap className="w-6 h-6 text-zinc-100" />
                  </div>
                  <p className="text-xs text-zinc-600 font-medium">Menunggu perintah...</p>
                </div>
              )}

              {loading && (
                <div className="flex flex-col items-center gap-4">
                  <div className="relative">
                    <div className="w-12 h-12 border-4 border-emerald-500/20 border-t-emerald-500 rounded-full animate-spin"></div>
                    <div className="absolute inset-0 flex items-center justify-center">
                      <div className="w-1.5 h-1.5 bg-emerald-500 rounded-full animate-pulse"></div>
                    </div>
                  </div>
                  <span className="text-xs font-bold tracking-widest text-emerald-500 animate-pulse">PROSESING...</span>
                </div>
              )}

              {error && (
                <div className="bg-red-500/10 border border-red-500/20 p-4 rounded-xl flex items-start gap-3">
                  <AlertCircle className="w-5 h-5 text-red-500 shrink-0" />
                  <p className="text-xs text-red-400 leading-relaxed">{error}</p>
                </div>
              )}

              {output && activeTab === 'deskripsi' && (
                <div className="w-full animate-in fade-in zoom-in-95 duration-500">
                  <p className="text-sm leading-relaxed text-zinc-300 font-medium whitespace-pre-wrap">
                    {output}
                  </p>
                  <button 
                    onClick={copyToClipboard}
                    className="absolute bottom-4 right-4 flex items-center gap-2 px-4 py-2 bg-zinc-800 hover:bg-emerald-600 rounded-lg text-xs font-bold transition-all shadow-xl border border-white/5"
                  >
                    {copied ? <CheckCircle2 className="w-3.5 h-3.5" /> : <Copy className="w-3.5 h-3.5" />}
                    {copied ? 'TERSALIN' : 'SALIN'}
                  </button>
                </div>
              )}

              {output && activeTab === 'generate' && (
                <div className="w-full h-full relative group animate-in zoom-in-95 duration-500">
                  <img src={output} alt="Generated" className="w-full h-full object-contain rounded-lg" />
                  <div className="absolute bottom-4 right-4 flex gap-2">
                    <button 
                      onClick={() => window.open(output, '_blank')}
                      className="p-3 bg-zinc-900/80 backdrop-blur-md rounded-xl text-zinc-100 hover:text-emerald-400 border border-white/10 transition-all"
                      title="Preview"
                    >
                      <Maximize2 className="w-4 h-4" />
                    </button>
                    <button 
                      onClick={downloadImage}
                      className="p-3 bg-emerald-600 rounded-xl text-white shadow-lg hover:bg-emerald-500 transition-all"
                      title="Download"
                    >
                      <Download className="w-4 h-4" />
                    </button>
                  </div>
                </div>
              )}
            </div>
          </section>
        </div>
      </main>

      {/* Background Decor */}
      <div className="fixed inset-0 pointer-events-none z-[-1] overflow-hidden">
        <div className="absolute top-[-10%] left-[-10%] w-[40%] h-[40%] bg-emerald-900/10 blur-[120px] rounded-full"></div>
        <div className="absolute bottom-[-10%] right-[-10%] w-[30%] h-[30%] bg-emerald-900/5 blur-[100px] rounded-full"></div>
      </div>

      {/* Footer */}
      <footer className="max-w-4xl mx-auto px-6 py-8 border-t border-zinc-900 mt-20">
        <div className="flex flex-col md:flex-row items-center justify-between gap-4 text-zinc-600">
          <p className="text-xs">© 2024 NYETAK • Professional Imaging AI</p>
          <div className="flex gap-6 text-xs uppercase tracking-widest font-bold">
            <span className="hover:text-emerald-500 cursor-pointer transition-colors">Clean UI</span>
            <span className="hover:text-emerald-500 cursor-pointer transition-colors">Model Nano Banana</span>
            <span className="hover:text-emerald-500 cursor-pointer transition-colors">Fast processing</span>
          </div>
        </div>
      </footer>
    </div>
  );
};

export default App;
